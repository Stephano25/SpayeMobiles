{
  "expo": {
    "name": "SPayeMobile",
    "slug": "spayemobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/image02.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/image02.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366f1"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spaye.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/image02.png",
        "backgroundColor": "#6366f1"
      },
      "package": "com.spaye.mobile"
    },
    "web": {
      "favicon": "./assets/image02.png"
    },
    "scheme": "spaye"
  }
}